generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  name      String?
  role      Role      @default(GUEST)
  bookings  Booking[]
  createdAt DateTime  @default(now())
}

model Room {
  id            String    @id @default(cuid())
  name          String
  description   String?
  pricePerNight Float
  maxGuests     Int
  images        String[]
  amenities     String[]
  available     Boolean   @default(true)
  bookings      Booking[]
}

model Booking {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  roomId           String
  room             Room          @relation(fields: [roomId], references: [id])
  checkIn          DateTime
  checkOut         DateTime
  guests           Int
  totalPrice       Float
  status           BookingStatus @default(PENDING)
  stripePaymentId  String?
  specialRequests  String?
  createdAt        DateTime      @default(now())
}

enum Role {
  GUEST
  ADMIN
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  CANCELLED
  COMPLETED
}
